# Database Configuration
DATABASE_URL=postgresql://voiceai:voiceaipassword@localhost:5432/voiceai_db
DB_POOL_SIZE=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Voice API Configuration
VOICE_API_KEY=your_voice_api_key_here
VOICE_API_PROVIDER=vapi  # Options: vapi, synthflow, assistable

# Voice API-specific URLs (optional, defaults are provided)
VAPI_BASE_URL=https://api.vapi.ai
SYNTHFLOW_BASE_URL=https://api.synthflow.ai
ASSISTABLE_BASE_URL=https://api.assistable.ai

# Lead Hoop Configuration
LEAD_HOOP_URL=https://leadhoop.com/login
LEAD_HOOP_USERNAME=your_username
LEAD_HOOP_PASSWORD=your_password
LEAD_HOOP_TIMEOUT=30  # seconds
LEAD_HOOP_RETRY_ATTEMPTS=3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your_secure_api_key_here

# Agent Configuration
VOICE_AGENT_POLLING_INTERVAL=5  # seconds
DATA_ENTRY_AGENT_POLLING_INTERVAL=5  # seconds
MAX_CONCURRENT_CALLS=5
MAX_CONCURRENT_ENTRIES=3
HEADLESS_BROWSER=true  # Set to false for debugging UI automation

# Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
ENVIRONMENT=development  # Options: development, production 